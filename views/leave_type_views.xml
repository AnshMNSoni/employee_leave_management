<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_leave_type_list" model="ir.ui.view">
        <field name="name">leave.type.list</field>
        <field name="model">leave.type</field>
        <field name="arch" type="xml">
            <list string="Leave Types">
                <field name="name"/>
                <field name="max_days"/>
                <field name="is_paid"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_leave_type_form" model="ir.ui.view">
        <field name="name">leave.type.form</field>
        <field name="model">leave.type</field>
        <field name="arch" type="xml">
            <form string="Leave Type">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="max_days"/>
                        <field name="is_paid"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_leave_type" model="ir.actions.act_window">
        <field name="name">Leave Types</field>
        <field name="res_model">leave.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
